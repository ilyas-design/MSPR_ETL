[run]
branch = True
source =
    Pipelines
    api
omit =
    */__init__.py
    */tests/*
    */migrations/*
    backend/config/*
    backend/manage.py
    scripts/*

[report]
show_missing = True
skip_covered = False
# MSPR2 stack spans ETL, Django API, nutrition-api and reco-engine; 100% is not
# realistic while LLM/vision paths stay integration-tested with mocks (target: 70%).
fail_under = 70

