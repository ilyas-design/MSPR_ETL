# --- HealthAI Social (mobile) — variables d'environnement Expo ---
# Les variables EXPO_PUBLIC_* sont injectées dans l'app au build/dev.
# Copiez ce fichier en .env puis adaptez selon votre environnement.

# URL de base de l'API Django (sans /api final).
#  - iOS simulateur          : http://localhost:8000
#  - Android emulateur (AVD)  : http://10.0.2.2:8000
#  - Appareil physique        : http://<IP-LAN-de-votre-machine>:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Mode démo hors-ligne : 1 = données mockées locales (aucun backend requis),
# 0 = appels réseau réels vers l'API. Couvre l'exigence "Configuration offline".
EXPO_PUBLIC_USE_MOCKS=0
