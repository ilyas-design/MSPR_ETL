      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_total_by_method_total[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "title": "Django — requêtes HTTP / s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU hôte",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(container_cpu_usage_seconds_total{cpu=\"total\",container_label_com_docker_compose_service=~\"backend|nutrition-api|reco-engine\"}[5m])) by (container_label_com_docker_compose_service)",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "B"
        }
      ],
      "title": "CPU — hôte (node-exporter) + services (cAdvisor)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
