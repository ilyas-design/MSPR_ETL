# =============================================================================
# HealthAI Coach — variables d'environnement (stack Docker Compose)
# =============================================================================
# Copier ce fichier à la racine du dépôt :
#   cp .env.example .env
#
# Utilisé par : docker compose, backend, nutrition-api, reco-engine, Airflow.
# Mobile (Expo) : voir apps/mobile/.env.example (variables EXPO_PUBLIC_*).
# =============================================================================

# --- Django backend (obligatoire) ---------------------------------------------
# Clé secrète Django — générer une valeur unique en local / démo.
# Exemple : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-generate-a-random-secret-key

# Mode debug (False en démo / soutenance ; True uniquement en dev natif)
DEBUG=False

# Chemin SQLite ETL (conteneur : /data/mspr_etl.db ; natif : ./mspr_etl.db)
# DB_PATH=/data/mspr_etl.db

# --- PostgreSQL applicatif (Django social, profils, posts) -------------------
# Valeurs par défaut alignées sur docker-compose (service app-postgres).
POSTGRES_DB=healthai
POSTGRES_USER=healthai
POSTGRES_PASSWORD=healthai
POSTGRES_HOST=app-postgres
POSTGRES_PORT=5432

# --- MongoDB (plans repas / sport IA, reco-engine) ---------------------------
MONGO_ROOT_USER=healthai
MONGO_ROOT_PASSWORD=healthai
MONGO_DB_NAME=healthai_plans
MONGO_HOST=mongo
MONGO_PORT=27017
# Optionnel : URI complète (prioritaire sur HOST/PORT/USER/PASSWORD)
# MONGO_URI=mongodb://healthai:change-me@mongo:27017/healthai_plans?authSource=admin

# --- Microservices (noms d'hôtes réseau Docker) ------------------------------
NUTRITION_API_URL=http://nutrition-api:8001
RECO_ENGINE_URL=http://reco-engine:8002

# --- IA externe (OpenRouter + USDA) ------------------------------------------
# Laisser vide pour désactiver les appels LLM (503 sauf mode MOCK_IA).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_MAX_TOKENS=6000
LLM_MAX_ATTEMPTS=3

# Enrichissement nutrition USDA (optionnel, nécessite Internet)
USDA_API_KEY=

# Mode offline stack : réponses IA statiques sans OpenRouter (voir docker-compose.offline.yml)
MOCK_IA=false

# --- Apache Airflow (orchestration ETL) --------------------------------------
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=mspr-airflow:latest
AIRFLOW__API_AUTH__JWT_SECRET=mspr_airflow_dev_jwt_secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow
# Compte UI Airflow (créé au premier init)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# --- Monitoring (profile : docker compose --profile monitoring up) -----------
# Grafana — identifiants UI http://localhost:3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# --- Lancement par configuration (TPRE601) -----------------------------------
# Complet (défaut)     : docker compose up --build -d
# + Monitoring         : docker compose --profile monitoring up --build -d
# Offline (mocks IA)   : ./infra/scripts/up-offline.sh
# Performance (léger)  : ./infra/scripts/up-perf.sh
#
# Sauvegarde / restauration :
#   ./infra/scripts/backup.sh
#   ./infra/scripts/restore.sh backups/YYYYMMDD-HHMMSS
#   ./infra/scripts/reset.sh --yes
