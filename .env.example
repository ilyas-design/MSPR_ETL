SECRET_KEY=your-secret-key-here
DEBUG=False

# MongoDB — dev-only defaults (override in production)
MONGO_ROOT_USER=healthai
MONGO_ROOT_PASSWORD=change-me-in-production
MONGO_DB_NAME=healthai_plans
# Used by backend inside Docker (service name on compose network)
MONGO_HOST=mongo
MONGO_PORT=27017
# Optional: full URI overrides MONGO_HOST/PORT/USER/PASSWORD when set
# MONGO_URI=mongodb://healthai:change-me-in-production@mongo:27017/healthai_plans?authSource=admin

# Microservices (Docker network hostnames)
NUTRITION_API_URL=http://nutrition-api:8001
RECO_ENGINE_URL=http://reco-engine:8002

# LLM workout plans (reco-engine only — dev key, never commit real secrets)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
